{
  "manifest_version": 3,
  "name": "ResumeAI — Auto Apply Jobs",
  "version": "1.1.0",
  "description": "Auto-apply to LinkedIn Easy Apply, Greenhouse, Lever, and Workable jobs from your ResumeAI campaign",
  "permissions": ["activeTab", "storage", "alarms", "notifications"],
  "host_permissions": [
    "https://www.linkedin.com/*",
    "https://resumeai.bot/*",
    "http://resumeai-bot.ru/*",
    "https://resumeai-bot.ru/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://www.linkedin.com/jobs/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
