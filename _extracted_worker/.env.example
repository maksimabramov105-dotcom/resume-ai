# Copy this file to .env and fill in real values before starting the worker.

# Required: shared secret for Bearer token auth on all /jobs/* routes
WORKER_SECRET=change-me-in-production

# Required: PostgreSQL connection string (asyncpg format)
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/resumeai

# OpenAI — required for resume generation and cover letter endpoints
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# CRITICAL: copy this value verbatim from the old .env
# Without the correct key, existing encrypted LinkedIn passwords cannot be decrypted.
ENCRYPTION_KEY=

# Adzuna job board API (free key at https://developer.adzuna.com)
ADZUNA_APP_ID=
ADZUNA_APP_KEY=

# Which job boards to enable (comma-separated)
# Valid values: adzuna, themuse, arbeitnow, remoteok
ENGLISH_JOB_SOURCES=adzuna,themuse,arbeitnow,remoteok

# Delay between LinkedIn applications (seconds)
MIN_APPLY_DELAY=30
MAX_APPLY_DELAY=90
