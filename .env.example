# Copy to .env and fill in your values

# ===== TELEGRAM =====
BOT_TOKEN=
ADMIN_ID=                          # Your Telegram ID (for manual payment approval)
ADMIN_TELEGRAM_ID=                 # Same as ADMIN_ID — used for backup notifications

# ===== AI / LLM =====
# Use either direct OpenAI OR OpenRouter (recommended — cheaper, more models)
OPENAI_API_KEY=
OPENROUTER_API_KEY=
OPENAI_MODEL=openai/gpt-4o-mini
OPENAI_MODEL_PREMIUM=openai/gpt-4o

# ===== DATABASE =====
DATABASE_URL=sqlite+aiosqlite:///./bot.db

# ===== AI ASSISTANT =====
ASSISTANT_FREE_MESSAGES=3
ASSISTANT_MAX_CONTEXT_MESSAGES=10

# ===== WEBAPP =====
WEBAPP_URL=https://resumeai-bot.ru          # Used by bot for deep links
WEBAPP_BASE_URL=https://resumeai-bot.ru     # Used by AutoApply for redirect URLs

# ===== SECURITY =====
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=                                  # REQUIRED — signs AutoApply JWT tokens
ADMIN_SECRET=                                # Admin API secret
ENCRYPTION_KEY=                              # Fernet key for encrypting stored credentials
LINK_SECRET=                                 # REQUIRED — shared between bot and autoapply for Telegram SSO link tokens

# ===== PAYMENTS — Stripe =====
# Get keys: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_live_...
STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
# Price IDs — run scripts/stripe_setup.py to create them, then paste here:
STRIPE_PRICE_TRIAL=price_...
STRIPE_PRICE_PRO_MONTHLY=price_...
STRIPE_PRICE_PREMIUM_MONTHLY=price_...

# ===== PAYMENTS — Revolut (manual, admin approval) =====
REVOLUT_TAG=@yourtag
REVOLUT_LINK=https://revolut.me/yourtag

# ===== EMAIL / SMTP =====
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=your@gmail.com

# ===== COUNTRY / JURISDICTION GATE =====
# ISO-3166-1 alpha-2 codes the worker must never apply to (comma-separated).
COUNTRY_BLOCKLIST=RU,BY
# STRICT_DOMICILE=1: vacancies whose company country can't be resolved are blocked.
# Set to 0 in dev/staging to allow unknown-country vacancies to pass.
STRICT_DOMICILE=1

# ===== JOB SEARCH APIs =====
# Adzuna (free tier 250 req/day): https://developer.adzuna.com/
ADZUNA_APP_ID=
ADZUNA_APP_KEY=
# Remotive, ArbeitNow, RemoteOK, The Muse: no key needed (free)
#
# NOTE (2026-05 international pivot): HH_CLIENT_ID, HH_CLIENT_SECRET,
# SUPERJOB_CLIENT_ID, and SUPERJOB_API_KEY have been intentionally removed.
# hh.ru and superjob.ru are no longer supported job sources.

# ===== DEMO VIDEO =====
# YouTube video ID for the landing-page demo section (the part after youtube.com/watch?v=)
# Leave blank to show the "coming soon" CTA button instead.
# Example: NEXT_PUBLIC_DEMO_VIDEO_ID=dQw4w9WgXcQ
NEXT_PUBLIC_DEMO_VIDEO_ID=

# ===== ANALYTICS =====
# PostHog: https://posthog.com (free tier)
POSTHOG_API_KEY=
POSTHOG_HOST=https://app.posthog.com
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
GA4_ID=G-XXXXXXXXXX

# ===== ERROR TRACKING =====
# Sentry: https://sentry.io (free tier)
SENTRY_DSN=

# ===== TELEGRAM CHANNEL (marketing) =====
TG_CHANNEL=@yourchannel

# ===== REDDIT (social marketing) =====
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USERNAME=
REDDIT_PASSWORD=
REDDIT_ACCESS_TOKEN=

# ===== TWITTER/X =====
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_SECRET=

# ===== RESEND (transactional email alternative) =====
RESEND_API_KEY=
RESEND_FROM=

# ===== REPLY INBOX WEBHOOK =====
INBOX_WEBHOOK_SECRET=         # Strong random string; protects /webhook/inbox from spoofed inbound email payloads

# ===== AUTOAPPLY WORKER =====
WORKER_INTERVAL=300                # Seconds between worker cycles
MIN_APPLY_DELAY=30                 # Min seconds between applications
MAX_APPLY_DELAY=120                # Max seconds between applications
AUTOAPPLY_HOST=0.0.0.0
AUTOAPPLY_PORT=8080

# ===== CAREER-OPS QUALITY ENGINE =====
# Controls the 🎯 quality path (engine='career_ops' campaigns).
# Node.js must be installed on the server for PDF generation.
# See docs/runbooks/upgrade-career-ops.md to bump the vendor/career-ops pin.
CAREER_OPS_MIN_SCORE=5.5          # Composite score threshold (0–10); apps below this are skipped
CAREER_OPS_CV_DIR=/opt/resumeaibot/cv  # Where scored CV PDFs are written
# CAREER_OPS_WORKDIR=             # Override vendor/career-ops working dir (default: auto-detected)

# ===== REFERRAL PROGRAM =====
# Codes are derived deterministically from user_id (base32 + SHA-256 checksum).
# No extra config needed — just ensure WEBAPP_URL above points to the correct domain.

# ===== BOT API SERVER =====
API_PORT=8000
API_HOST=0.0.0.0
