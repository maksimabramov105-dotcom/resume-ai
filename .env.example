# Copy to .env and fill in your values

# ===== TELEGRAM =====
BOT_TOKEN=
ADMIN_ID=                          # Your Telegram ID (for manual payment approval)
ADMIN_TELEGRAM_ID=                 # Same as ADMIN_ID — used for backup notifications

# ===== AI / LLM =====
# Use either direct OpenAI OR OpenRouter (recommended — cheaper, more models)
OPENAI_API_KEY=
OPENROUTER_API_KEY=
OPENAI_MODEL=openai/gpt-4o-mini
OPENAI_MODEL_PREMIUM=openai/gpt-4o

# ===== DATABASE =====
DATABASE_URL=sqlite+aiosqlite:///./bot.db

# ===== AI ASSISTANT =====
ASSISTANT_FREE_MESSAGES=3
ASSISTANT_MAX_CONTEXT_MESSAGES=10

# ===== WEBAPP =====
WEBAPP_URL=https://resumeai-bot.ru          # Used by bot for deep links
WEBAPP_BASE_URL=https://resumeai-bot.ru     # Used by AutoApply for redirect URLs

# ===== SECURITY =====
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=                                  # REQUIRED — signs AutoApply JWT tokens
ADMIN_SECRET=                                # Admin API secret
ENCRYPTION_KEY=                              # Fernet key for encrypting stored credentials

# ===== PAYMENTS — CryptoBot =====
# Get token: @CryptoBot → /pay → Create App
CRYPTOBOT_TOKEN=
CRYPTOBOT_AUTOAPPLY_TOKEN=                  # Separate CryptoBot app for AutoApply

# ===== PAYMENTS — Manual card (RU) =====
RU_CARD_NUMBER=0000 0000 0000 0000
RU_CARD_HOLDER=Иван И.
RU_BANK_NAME=Сбербанк

# ===== PAYMENTS — Revolut =====
REVOLUT_TAG=@yourtag
REVOLUT_LINK=https://revolut.me/yourtag

# ===== PAYMENTS — Stripe =====
# Get keys: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_live_...
STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
# Price IDs — run scripts/stripe_setup.py to create them, then paste here:
STRIPE_PRICE_TRIAL=price_...
STRIPE_PRICE_PRO_MONTHLY=price_...
STRIPE_PRICE_PREMIUM_MONTHLY=price_...

# ===== EMAIL / SMTP =====
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=your@gmail.com

# ===== JOB SEARCH APIs =====
# Adzuna (free tier 250 req/day): https://developer.adzuna.com/
ADZUNA_APP_ID=
ADZUNA_APP_KEY=
# Remotive, ArbeitNow, RemoteOK, The Muse: no key needed (free)

# ===== ANALYTICS =====
# PostHog: https://posthog.com (free tier)
POSTHOG_API_KEY=
POSTHOG_HOST=https://app.posthog.com
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
GA4_ID=G-XXXXXXXXXX
YANDEX_METRIKA_ID=

# ===== ERROR TRACKING =====
# Sentry: https://sentry.io (free tier)
SENTRY_DSN=

# ===== TELEGRAM CHANNEL (marketing) =====
TG_CHANNEL=@yourchannel

# ===== VK (social marketing) =====
VK_API_TOKEN=
VK_ACCESS_TOKEN=
VK_GROUP_ID=
VK_OWNER_ID=

# ===== REDDIT (social marketing) =====
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USERNAME=
REDDIT_PASSWORD=
REDDIT_ACCESS_TOKEN=

# ===== TWITTER/X =====
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_SECRET=

# ===== RESEND (transactional email alternative) =====
RESEND_API_KEY=
RESEND_FROM=

# ===== AUTOAPPLY WORKER =====
WORKER_INTERVAL=300                # Seconds between worker cycles
MIN_APPLY_DELAY=30                 # Min seconds between applications
MAX_APPLY_DELAY=120                # Max seconds between applications
AUTOAPPLY_HOST=0.0.0.0
AUTOAPPLY_PORT=8080
