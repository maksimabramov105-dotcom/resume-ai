# Скопируй в .env и заполни своими данными

# Telegram
BOT_TOKEN=
ADMIN_ID=                          # Твой Telegram ID (для подтверждения ручных платежей)

# OpenAI (прямое подключение) — заполни одно из двух
OPENAI_API_KEY=

# OpenRouter (рекомендуется — дешевле, больше моделей)
# Получи ключ: https://openrouter.ai/keys
OPENROUTER_API_KEY=
# Модели для OpenRouter: openai/gpt-4o-mini, google/gemini-flash-1.5, anthropic/claude-3-haiku, mistralai/mistral-7b-instruct:free
OPENAI_MODEL=openai/gpt-4o-mini
OPENAI_MODEL_PREMIUM=openai/gpt-4o

# Database
DATABASE_URL=sqlite+aiosqlite:///./bot.db

# AI Assistant
ASSISTANT_FREE_MESSAGES=3
ASSISTANT_MAX_CONTEXT_MESSAGES=10

# ===== ОПЛАТА =====

# 1. CryptoBot — получи токен: @CryptoBot → /pay → Create App
CRYPTOBOT_TOKEN=

# 2. Карта РФ (ручной перевод)
RU_CARD_NUMBER=0000 0000 0000 0000
RU_CARD_HOLDER=Иван И.
RU_BANK_NAME=Сбербанк

# 3. Revolut (ручной перевод)
REVOLUT_TAG=@yourtag
REVOLUT_LINK=https://revolut.me/yourtag

# ===== EMAIL / SMTP =====
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=your@gmail.com
WEBAPP_BASE_URL=https://resumeai-bot.ru

# ===== STRIPE (платёжная система) =====
# Получи ключи: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRO_PRICE_ID=price_...
STRIPE_UNLIMITED_PRICE_ID=price_...

# ===== JOB SEARCH API =====
# Adzuna (free tier): https://developer.adzuna.com/
ADZUNA_APP_ID=
ADZUNA_API_KEY=
# Remotive: no key needed (free)

# ===== ANALYTICS =====
# PostHog: https://posthog.com (free tier)
POSTHOG_API_KEY=
POSTHOG_HOST=https://app.posthog.com

# ===== ERROR TRACKING =====
# Sentry: https://sentry.io (free tier)
SENTRY_DSN=

# ===== ADMIN API =====
ADMIN_SECRET=your-secret-here
TELEGRAM_CHANNEL_ID=@yourchannel


# ===== HH.RU SCRAPER =====
# Register app at https://dev.hh.ru/ → "Мои приложения" to get credentials
# Without these all vacancy searches return HTTP 403
HH_CLIENT_ID=
HH_CLIENT_SECRET=
SUPERJOB_API_KEY=
