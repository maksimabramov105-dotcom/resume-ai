# Скопируй в .env и заполни своими данными

# Telegram
BOT_TOKEN=
ADMIN_ID=

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_MODEL_PREMIUM=gpt-4o

# Payment (ЮKassa)
YUKASSA_SHOP_ID=
